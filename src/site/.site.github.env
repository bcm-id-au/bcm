#
#
# Site: GitHub Secrets example file
#   - Add new GitHub Environments (GitHub Repo > Settings > Code and automation > Environments):
#     - ci-build
#     - github-packages
#     - github-pages
#     - (Optional) gcp-cloud-run
#   - Add a new Secret for each item below:
#     - Follow the navigation steps in each section to ensure it's added to the right area
#     - Set the name to the value before the '=' below, eg: SITE_AUTHOR
#     - Set the value of each new Secret to suit your site
#
#

# ----
# Repository Secrets
# ----
#
# Add these to:
#   GitHub Repo > Settings >  Security and qaulity > Secrets and variables >
#   Actions > Repository secrets
#

# Must be in this format:
# (github_username)/(this_repo_name)(optional_suffix)
SITE_DOCKER_IMAGE_PATH="janedoe/jane-site"

# To enable the optional deploy to GCP, set to: true
# To disable the optional deploy to GCP, set to: false
SITE_GCP_DEPLOY_ENABLED=false

# ----
# CI Build
# ----
#
# Add these to:
#   GitHub Repo > Settings > Code and automation > Environments >
#   ci-build > Add environment secret
#

# Temporary build directory
SITE_BUILD_DIR="build"

# Static build output directory
SITE_PUBLIC_DIR="public"

# Site details
SITE_AUTHOR="Jane Doe"
SITE_URL="https://jane-doe.com/"
SITE_LANG="en-GB"

# Blog posts
SITE_POSTS_DIR="content/posts"
SITE_POSTS_URL="https://jane-doe.com/posts/"
SITE_FEED_TITLE="Posts by Jane Doe"
SITE_FEED_DESC="Jane writes about technology and the climate."
SITE_FEED_DEFAULT_TITLE="Post by Jane Doe"
SITE_FEED_FILE="public/jane/posts.json"
SITE_FEED_URL="https://jane-doe.com/jane/posts.json"

# ----
# (Optional) GitHub Environment: gcp-cloud-run
# ----
#
# Add these to:
#   GitHub Repo > Settings > Code and automation > Environments >
#   gcp-cloud-run > Add environment secret
#
# Requires initial manual setup detailed in:
#   README.md > Infrastructure
#
#

SITE_GCP_PROJECT_ID="jane-site-111222"

SITE_GCP_REGION="asia-southeast1"

SITE_GCP_CLOUD_RUN_SERVICE_NAME="jane-site-production"

SITE_GCP_DOCKER_IMAGE_URL="asia-southeast1-docker.pkg.dev/xxxx/github-packages"

# The full content of the JSON file from Step 6
SITE_GCP_SERVICE_ACCOUNT_JSON="{...}"
