#
#
# Site: GitHub Secrets example file
#   - Add new GitHub Environments (GitHub Repo > Settings > Code and automation > Environments):
#     - ci-build
#     - gcp-cloud-run
#     - github-packages
#     - github-pages
#   - Add a new Secret for each item below:
#     - GitHub Repo > Settings > Code and automation > Environments > (Environment) > Add environment secret
#     - Set the name to the value before the '=' below, eg: SITE_AUTHOR
#     - Set the value of each new Secret to suit your site
#
#

# ----
# GitHub Environment: ci-build
# ----

# Temporary build directory
SITE_BUILD_DIR="build"

# Static build output directory
SITE_PUBLIC_DIR="public"

# Site details
SITE_AUTHOR="Jane Doe"
SITE_URL="https://jane-doe.com/"
SITE_LANG="en-GB"

# Blog posts
SITE_POSTS_DIR="content/posts"
SITE_POSTS_URL="https://jane-doe.com/posts/"
SITE_FEED_TITLE="Posts by Jane Doe"
SITE_FEED_DESC="Jane writes about technology and the climate."
SITE_FEED_DEFAULT_TITLE="Post by Jane Doe"
SITE_FEED_FILE="public/jane/posts.json"
SITE_FEED_URL="https://jane-doe.com/jane/posts.json"

# ----
# GitHub Environment: gcp-cloud-run
# ----
#
# Requires initial manual setup in Google Cloud:
#
#  1. Enable these Google Cloud APIs:
#    - Artifact Registry
#    - Cloud Run
#    - IAM Credentials
#  2. Setup a new Workload Identity Provider with these Roles:
#    - Artifact Registry Administrator
#    - Cloud Run Developer
#  3. Setup a new Service Account:
#    - Name: site-deployer
#    - Permissions:
#       - Artifact Registry Administrator
#       - Cloud Run Developer
#       - Service Account User
#    - Description: Used by GitHub Actions to deploy to Cloud Run
#    - Then save this, go to the Keys tab and click: Add key > Create new key > JSON > Create
#    - WARNING: Treat this JSON file as a password!
#      After you've saved it to GitHub Secrets, permanently delete the file.
#

SITE_GCP_PROJECT_ID="jane-site-111222"
SITE_GCP_REGION="asia-southeast1"
SITE_GCP_CLOUD_RUN_SERVICE_NAME="jane-site"

# The full content of the JSON file from Step 3
SITE_GCP_SERVICE_ACCOUNT_JSON="..."
