#
#
# Site: Local environment example file
#   - Copy this file to '.site.env' and update that file to match your site
#
#

# Temporary build directory
SITE_BUILD_DIR="build"

# Static build output directory
SITE_PUBLIC_DIR="public"

# Site details
SITE_AUTHOR="Brendan Murty"
SITE_URL="https://murty.au/"
SITE_LANG="en-GB"

# Blog posts
SITE_POSTS_DIR="content/posts"
SITE_POSTS_URL="https://murty.au/posts/"
SITE_FEED_TITLE="Posts by Brendan Murty"
SITE_FEED_DESC="Brendan is a Father, Schnitzel Reviewer, Software Engineering Manager and Technical Lead."
SITE_FEED_DEFAULT_TITLE="Post by Brendan Murty"
SITE_FEED_FILE="public/brendan/posts.json"
SITE_FEED_URL="https://murty.au/brendan/posts.json"
