{
  "compilerOptions": {
    "types": [
      "lume/types.ts"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "lume"
  },
  "fmt": {
    "include": [
      "src/",
      "_config.ts",
      "deno.json"
    ],
    "useTabs": false,
    "lineWidth": 120,
    "indentWidth": 2,
    "semiColons": true
  },
  "lint": {
    "include": [
      "src/",
      "config/lume.config.ts",
      "deno.json"
    ],
    "plugins": [
      "https://cdn.jsdelivr.net/gh/lumeland/lume@3.2.4/lint.ts"
    ],
    "rules": {
      "exclude": [
        "no-import-prefix"
      ]
    }
  },
  "imports": {
    "@gnome/exec": "jsr:@gnome/exec@^0.6",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/datetime": "jsr:@std/datetime@^0.225.7",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.6",
    "@std/http/file-server": "jsr:@std/http@^1.1.0/file-server",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/yaml": "jsr:@std/yaml@^1.1.0",
    "is_json/": "https://deno.land/x/is_json@v1.0.2/",
    "lume/": "https://cdn.jsdelivr.net/gh/lumeland/lume@3.2.4/",
    "lume/jsx-runtime": "https://cdn.jsdelivr.net/gh/oscarotero/ssx@0.1.14/jsx-runtime.ts"
  },
  "nodeModulesDir": "none",
  "tasks": {
    "build": {
      "description": "Build the site and organise the required assets.",
      "command": "cd ../.. && bash ./bin/site/site-build.sh"
    },
    "deps-install": {
      "description": "Install the project's dependencies.",
      "command": "deno install --quiet --entrypoint ./deno.json --config ./deno.json"
    },
    "deps-update": {
      "description": "Update the project's dependencies.",
      "command": "deno outdated --quiet --update --compatible --lock ./deno.lock"
    },
    "docker-build": {
      "description": "Build a local Docker image",
      "command": "cd ../.. && docker build --file src/site/Dockerfile --tag bcm-site-image ."
    },
    "docker-run": {
      "description": "Start a container using the local Docker image",
      "command": "deno task docker-stop && docker run -d -p 8000:8000 --name=bcm-site --rm bcm-site-image"
    },
    "docker-stop": {
      "description": "Stop and remove the Docker container",
      "command": "docker stop bcm-site &>/dev/null && docker rm bcm-site &>/dev/null || true"
    },
    "json-feed": {
      "description": "Generate a JSON feed of blog posts.",
      "command": "deno run --allow-read --allow-write --allow-env src/json-feed.ts"
    },
    "lint": {
      "description": "Run Deno's linting and formatting tools with the configuration defined above.",
      "command": "deno lint && deno fmt"
    },
    "lume": {
      "description": "Run Lume command",
      "command": "deno run -P=lume lume/cli.ts"
    },
    "new-post": {
      "description": "Generate a Markdown file for a new post item.",
      "command": "cd ../.. && bash ./bin/site/site-new-post.sh"
    },
    "release-notes": {
      "description": "Generates content for the GitHub Release description.",
      "command": "cd ../.. && bash ./bin/release/release-notes.sh"
    },
    "serve": {
      "description": "Start a local web server.",
      "command": "deno run --allow-net --allow-read jsr:@std/http/file-server ./public --port 8000"
    },
    "setup": {
      "description": "Setup directories, check for and install dependencies, used for local environments and in CI.",
      "command": "cd ../.. && bash ./bin/site/site-setup.sh"
    },
    "test": {
      "description": "Run all Deno Test scripts in the 'src' directory.",
      "command": "deno test --allow-run=deno --allow-env --allow-read --allow-net src"
    }
  },
  "permissions": {
    "lume": {
      "read": true,
      "write": [
        "./"
      ],
      "import": [
        "cdn.jsdelivr.net:443",
        "jsr.io:443",
        "deno.land:443",
        "esm.sh:443"
      ],
      "net": [
        "0.0.0.0",
        "cdn.jsdelivr.net:443",
        "data.jsdelivr.com:443",
        "jsr.io:443",
        "deno.land:443",
        "esm.sh:443",
        "registry.npmjs.org:443"
      ],
      "env": true,
      "run": true,
      "ffi": true,
      "sys": true
    }
  },
  "unstable": [
    "fmt-component"
  ],
  "allowScripts": {
    "deny": [
      "npm:sharp"
    ]
  },
  "lock": true
}
