{
  "lock": true,
  "nodeModulesDir": "none",
  "imports": {
    "@gnome/exec": "jsr:@gnome/exec@^0.6",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/datetime": "jsr:@std/datetime@^0.225.7",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.7",
    "@std/http/file-server": "jsr:@std/http@^1.1.1/file-server",
    "@std/fs": "jsr:@std/fs@^1.0.24",
    "@std/path": "jsr:@std/path@^1.1.5",
    "@std/yaml": "jsr:@std/yaml@^1.1.1",
    "chalk": "npm:chalk@^5.6.2",
    "highlight": "npm:highlight.js@^11.11.1",
    "is_json/": "https://deno.land/x/is_json@v1.0.2/",
    "lume/": "https://cdn.jsdelivr.net/gh/lumeland/lume@3.2.6/",
    "lume/jsx-runtime": "https://cdn.jsdelivr.net/gh/oscarotero/ssx@0.1.15/jsx-runtime.ts"
  },
  "tasks": {
    "build": {
      "description": "Build the site and organise the required assets.",
      "command": "bash ./bin/site-build.sh"
    },
    "install": {
      "description": "Install third-party dependencies.",
      "command": "deno install --quiet --config ./deno.jsonc --lock ./deno.lock"
    },
    "update": {
      "description": "Update third-party dependencies.",
      "command": "deno outdated --quiet --update --compatible --lock ./deno.lock"
    },
    "lint": {
      "description": "Run linting and formatting tools.",
      "command": "deno lint && deno fmt"
    },
    "lume": {
      "description": "Run a Lume command.",
      "command": "deno run --quiet -P=lume lume/cli.ts --config=src/lume.config.ts"
    },
    "new-post": {
      "description": "Generate a Markdown file for a new post item.",
      "command": "bash ./bin/site-new-post.sh"
    },
    "start": {
      "description": "Start a local web server.",
      "command": "bash ./bin/site-start.sh"
    },
    "setup": {
      "description": "Local environment setup.",
      "command": "bash ./bin/site-setup.sh"
    },
    "test": {
      "description": "Run all Deno Test scripts in the 'src' directory.",
      "command": "deno test --quiet --allow-run=deno --allow-env --allow-read --allow-net src"
    },
    "docker-build": {
      "description": "Run the Docker Image build process.",
      "command": "bash ./bin/site-docker-build.sh"
    },
    "docker-start": {
      "description": "Start the Docker Container.",
      "command": "bash ./bin/site-docker-start.sh"
    },
    "docker-stop": {
      "description": "Stop the Docker Container.",
      "command": "bash ./bin/site-docker-stop.sh"
    }
  },
  "compilerOptions": {
    "types": [
      "lume/types.ts"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "lume"
  },
  "fmt": {
    "include": [
      "src/",
      "deno.jsonc"
    ],
    "lineWidth": 100,
    "useTabs": false,
    "indentWidth": 2,
    "semiColons": true
  },
  "lint": {
    "include": [
      "src/",
      "deno.jsonc"
    ],
    "plugins": [
      "https://cdn.jsdelivr.net/gh/lumeland/lume@3.2.6/lint.ts"
    ],
    "rules": {
      "exclude": [
        "no-import-prefix"
      ]
    }
  },
  "permissions": {
    "lume": {
      "read": true,
      "write": [
        "./"
      ],
      "import": [
        "cdn.jsdelivr.net:443",
        "jsr.io:443",
        "deno.land:443",
        "esm.sh:443"
      ],
      "net": [
        "0.0.0.0",
        "cdn.jsdelivr.net:443",
        "data.jsdelivr.com:443",
        "jsr.io:443",
        "deno.land:443",
        "esm.sh:443",
        "registry.npmjs.org:443"
      ],
      "env": true,
      "run": true,
      "ffi": true,
      "sys": true
    }
  },
  "allowScripts": {
    "allow": [],
    "deny": ["npm:esbuild@0.27.3", "npm:esbuild@0.28.0", "npm:fs-ext@2.0.0"]
  }
}
