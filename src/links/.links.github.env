#
#
# Site: GitHub Secrets example file
#   - Initial manual setup required, follow steps in: src/links/README.md > Infrastructure
#   - Add a new Secret for each item below:
#     - Follow the navigation steps in each section to ensure it's added to the right area
#     - Set the name to the value before the '=' below, eg: LINKS_GCP_REGION
#     - Set the value of each new Secret to suit your setup
#
#

#
# ----
# Repository Secrets
# ----
#
# Add these to:
#   GitHub Repo > Settings >  Security and qaulity > Secrets and variables >
#   Actions > Repository secrets
#

# Must be in this format:
# (github_username)/(this_repo_name)(optional_suffix)
LINKS_DOCKER_IMAGE_PATH="janedoe/jane-links"

#
# ----
# GitHub Environment: gcp-cloud-run
# ----
#

LINKS_GCP_PROJECT_ID="jane-links-333444"
LINKS_GCP_REGION="asia-southeast1"
LINKS_GCP_CLOUD_RUN_SERVICE_NAME="jane-links-production"
LINKS_GCP_DOCKER_IMAGE_URL="asia-southeast1-docker.pkg.dev/xxxx/github-packages"
LINKS_GCP_SERVICE_ACCOUNT_JSON="{...}"
