APP_NAME=bcm-git
APP_SLOGAN="Git service"
APP_DISPLAY_NAME_FORMAT="{APP_NAME}"

APP_THEME_LIST="bcm,forgejo-auto,forgejo-light,forgejo-dark"
APP_THEME_DEFAULT="bcm"

ROOT_URL=http://localhost:3030/
PORT_WEB=3030
PORT_SSH=2022

POSTGRES_USER=forgejo
POSTGRES_PASSWORD=forgejo
POSTGRES_DB=forgejo

STORAGE_DIR_CUSTOM=/home/example/git/bcm/src/git/custom
STORAGE_DIR_APP=/home/example/git/bcm/storage/git/app
STORAGE_DIR_FILES=/home/example/git/bcm/storage/git/assets
STORAGE_DIR_GIT=/home/example/git/bcm/storage/git/repos
STORAGE_DIR_DATABASE=/home/example/git/bcm/storage/git/database
