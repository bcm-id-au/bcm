{
  "languages": {
    "JSON": {
      "format_on_save": "off",
      "auto_indent_on_paste": false,
      "auto_indent": "none",
      "tab_size": 2,
      "ensure_final_newline_on_save": false
    },
    "JSONC": {
      "format_on_save": "off",
      "auto_indent_on_paste": false,
      "auto_indent": "none",
      "tab_size": 2,
      "ensure_final_newline_on_save": false
    },
    "JavaScript": {
      "language_servers": [
        "deno",
        "!typescript-language-server",
        "!vtsls",
        "!eslint",
      ],
      "formatter": "language_server",
    },
    "TypeScript": {
      "language_servers": [
        "deno",
        "!typescript-language-server",
        "!vtsls",
        "!eslint",
      ],
      "formatter": "language_server",
    },
    "TSX": {
      "language_servers": [
        "deno",
        "!typescript-language-server",
        "!vtsls",
        "!eslint",
      ],
      "formatter": "language_server",
    },
  },
  "lsp": {
    "deno": {
      "settings": {
        "deno": {
          "enable": true,
          "lint": true,
          "config": "./deno.json",
          "importMap": "./deno.json",
        },
      },
    },
    "json-language-server": {
      "settings": {
        "json": {
          "schemas": [
            {
              "fileMatch": ["deno.json", "deno.jsonc"],
              "url": "https://raw.githubusercontent.com/denoland/deno/refs/heads/main/cli/schemas/config-file.v1.json",
            },
          ],
        },
      },
    },
  },
}
